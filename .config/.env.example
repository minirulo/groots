# ── API ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
DEBUG=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_SERVER=localhost
MONGO_PORT=27017
MONGO_USER=groots
MONGO_PASSWORD=groots
MONGO_AUTH_DB=admin
MONGO_DB=groots
# Leave empty to auto-assemble from the above fields:
MONGO_DB_URI=

# ── IPFS / Kubo ───────────────────────────────────────────────────────────────
IPFS_API_HOST=localhost
IPFS_API_PORT=5001
IPFS_GATEWAY_HOST=localhost
IPFS_GATEWAY_PORT=8080
