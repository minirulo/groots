# ── API ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
DEBUG=true

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=10080  # 7 days

# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_SERVER=localhost
MONGO_PORT=27017
MONGO_USER=groots
MONGO_PASSWORD=groots
MONGO_AUTH_DB=admin
MONGO_DB=groots
# Leave empty to auto-assemble from the above fields:
MONGO_DB_URI=

# ── IPFS / Kubo + Cluster ────────────────────────────────────────────────────
# In dev the API host points to the cluster proxy (9095), not Kubo directly (5001).
# The proxy is Kubo-API-compatible and adds cluster-side pin tracking on top.
IPFS_API_HOST=localhost
IPFS_API_PORT=9095
IPFS_GATEWAY_HOST=localhost
IPFS_GATEWAY_PORT=8080

# Shared secret that authenticates IPFS Cluster peers to each other.
# Generate: python3 -c "import secrets; print(secrets.token_hex(32))"
# Dev value (also set in docker-compose.dev.yml):
CLUSTER_SECRET=3fd62fee9be0ff16ea2a2b375269df9ba083087be6a90f6853c29839ae91c023
